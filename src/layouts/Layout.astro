---
import "../styles/reset.css";
import "../styles/variables.css";
import "../styles/globals.css";
import icEi from "../assets/ic-ei.svg?url";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Eiter — Graphic Designer",
  description = "Portfolio of Eiter, a graphic designer based in Vietnam.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0b0b" />
    <link rel="icon" href={icEi} type="image/svg+xml" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
