---
import work1 from "../../assets/works/work-1.svg?url";
import work2 from "../../assets/works/work-2.svg?url";
import work3 from "../../assets/works/work-3.svg?url";
import work4 from "../../assets/works/work-4.svg?url";
import work5 from "../../assets/works/work-5.svg?url";
import eiterLogo from "../../assets/ei-main.svg?url";
import work2Pic1 from "../../assets/works/work-2/pic1.png?url";
import work2Pic2 from "../../assets/works/work-2/pic2.png?url";
import work2Pic3 from "../../assets/works/work-2/pic3.png?url";
import work2Pic4 from "../../assets/works/work-2/pic4.png?url";
import work2Pic5 from "../../assets/works/work-2/pic5.png?url";
import work2Pic6 from "../../assets/works/work-2/pic6.png?url";
import work2Drag1 from "../../assets/works/work-2/drag1.svg?url";
import work2Drag2 from "../../assets/works/work-2/drag2.svg?url";
import work2Drag3 from "../../assets/works/work-2/drag3.svg?url";
import work3Drag1 from "../../assets/works/work-3/drag1.svg?url";
import work3Drag2 from "../../assets/works/work-3/drag2.svg?url";
import work3Drag3 from "../../assets/works/work-3/drag3.svg?url";
import work3Drag4 from "../../assets/works/work-3/drag4.svg?url";
import work3Img1 from "../../assets/works/work-3/img1.svg?url";
import work3Img2 from "../../assets/works/work-3/img2.svg?url";
import work3Img3 from "../../assets/works/work-3/img3.svg?url";
import work3Img4 from "../../assets/works/work-3/img4.svg?url";
import work3Img5 from "../../assets/works/work-3/img5.svg?url";
import triangleLeft from "../../assets/triangle-left.svg?url";
import triangleRight from "../../assets/triangle-right.svg?url";
import arrowRight from "../../assets/arrow-right.svg?url";
import arrowUp from "../../assets/arrow-up.svg?url";
import closeIcon from "../../assets/ic-close.svg?url";

const projects = [
  { name: "Lotus Water Puppet", preview: work1 },
  { name: "Crescent", preview: work2, type: "Branding and identity", client: "Crescent scented candles", year: "2025", heading: "Crescent", statement: "“Scent the Moment”", copy: "Crescent is a scented-candle identity built around the crescent moon: a timeless symbol of calm, ritual and a moment held just for yourself." },
  { name: "Holiday Inn", preview: work3, type: "Campaign", client: "Holiday Inn", year: "2024", heading: "Holiday Inn", statement: "“A second. A perfect stay”", copy: "A digital campaign that makes every small moment of a stay feel effortless, welcoming and ready when guests need it." },
  { name: "Rong Vang Hoang Gia", preview: work4, type: "Packaging", client: "Rong Vang Hoang Gia", year: "2024", heading: "Rong Vang Hoang Gia", statement: "“The Moon of Hope — The Moments of Longing”", copy: "A mooncake packaging system that turns the Mid-Autumn reunion into a bright, contemporary collection of stories." },
  { name: "Antibiotic Abuse", preview: work5, type: "Campaign", client: "Antibiotics are not the answer", year: "2024", heading: "Antibiotics Are Not the Answer", statement: "Antibiotic Resistance", copy: "A public-awareness campaign about the risks of unnecessary antibiotic use and the everyday choices that help protect public health." },
];

const crescentDragItems = [
  { image: work2Drag1, position: "top: 0; left: 43%;" },
  { image: work2Drag2, position: "top: 11rem; left: 4%;" },
  { image: work2Drag3, position: "top: 12rem; right: 4%;" },
];

const holidayDragItems = [
  { image: work3Drag1, position: "top: 0; left: 39%;" },
  { image: work3Drag2, position: "top: 9rem; left: 1%;" },
  { image: work3Drag3, position: "top: 11rem; right: 1%;" },
  { image: work3Drag4, position: "top: 21rem; left: 32%;" },
];
---

<section class="works-panel" data-panel="works" hidden aria-labelledby="works-heading">
  <h2 id="works-heading" class="sr-only">Works</h2>
  <div class="works-panel__grid" role="list">
    {projects.map(({ name, preview }, index) => (
      <button class="work-folder" type="button" data-folder data-project={name} data-work-modal-trigger={index === 1 || index === 2 ? index : undefined} aria-haspopup={index === 1 || index === 2 ? "dialog" : undefined} aria-expanded="false" disabled={index !== 1 && index !== 2} role="listitem">
        <span class="work-folder__art" aria-hidden="true">
          <span class="work-folder__back">
            <span class="work-folder__paper">
              <span class="work-folder__preview">
                <img src={preview} alt="" />
              </span>
              <span class="work-folder__front"><b>{String(index + 1).padStart(2, "0")}</b></span>
            </span>
          </span>
        </span>
        <span class="work-folder__name">{name}</span>
      </button>
    ))}
  </div>

  <aside class="works-panel__detail" data-work-detail aria-live="polite" hidden>
    <button type="button" data-work-detail-close aria-label="Close project detail"><img src={closeIcon} alt="" /></button>
    <p>Selected project</p>
    <h3 data-work-detail-title></h3>
    <span>Artwork and project details will be added here.</span>
  </aside>

  <div class="work-modal" data-work-modal hidden aria-hidden="true">
    <button class="work-modal__backdrop" type="button" data-work-modal-close aria-label="Close project detail"></button>
    <article class="work-modal__window work-modal--crescent" data-work-modal-panel="1" role="dialog" aria-modal="true" aria-labelledby="work-modal-title-1" hidden>
      <header class="work-modal__bar">
        <span>Works</span>
        <button type="button" data-work-modal-close aria-label="Close Crescent"><img src={closeIcon} alt="" /></button>
      </header>
      <div class="work-modal__body">
        <section class="crescent-intro">
          <div class="crescent-intro__meta">
            <p class="work-modal__number">02</p>
            <h3 id="work-modal-title-1">Crescent</h3>
            <dl>
              <div><dt>Type of work:</dt><dd>Branding and identity</dd></div>
              <div><dt>Client:</dt><dd>Crescent scented candles</dd></div>
              <div><dt>Year:</dt><dd>2025</dd></div>
              <div><dt>Participants:</dt><dd>Chu Phuong Anh</dd></div>
            </dl>
          </div>
          <img class="crescent-intro__eiter" src={eiterLogo} alt="Eiter" />
          <div class="crescent-drag-area" aria-label="Crescent image previews">
            {crescentDragItems.map(({ image, position }, card) => (
              <img class:list={["crescent-drag-card", `crescent-drag-card--${card + 1}`]} style={`position: absolute; ${position}`} src={image} alt="" draggable="false" data-modal-draggable />
            ))}
          </div>
        </section>

        <section class="crescent-copy">
          <span class="crescent-copy__marker" aria-hidden="true" style="display: block; width: 31px; height: 31px; margin: 0 0 26px; background: var(--color-mint);"></span>
          <span class="crescent-copy__markers crescent-copy__markers--right" aria-hidden="true" style="display: flex; gap: 35px; position: absolute; top: 16px; right: clamp(1.4rem, 6vw, 3.6rem);"><span class="crescent-copy__marker" style="display: block; flex: 0 0 31px; width: 31px; height: 31px; background: var(--color-mint);"></span><span class="crescent-copy__marker" style="display: block; flex: 0 0 31px; width: 31px; height: 31px; background: var(--color-mint);"></span></span>
          <h4>Crescent</h4>
          <div class="work-modal__columns">
            <p>The brand name was selected to capture the serene essence of a crescent moon, a timeless global symbol for peace, gradual renewal, and understated beauty. In a modern landscape dominated by constant rush and noise, this identity serves as a quiet reminder to pause.</p>
            <p>On a deeper, structural level, the word itself holds a beautiful linguistic coincidence. Nested right within “Crescent” is the word “scent”, seamlessly anchoring the brand to its aromatic purpose and the calm of nighttime rituals.</p>
          </div>
          <div class="crescent-logo"><img src={work2} alt="Crescent logo" /></div>
          <h4 class="crescent-copy__statement">“Scent the Moment”</h4>
          <div class="work-modal__columns">
            <p>Our core tagline functions as a philosophy rather than a commercial slogan. It was designed to transform how users interact with their environments and to make small routines feel personal and restorative.</p>
            <p>This statement highlights a commitment to holistic emotional healing and design-forward wellness. A natural scent becomes a physical ritual: easing tension, uplifting moods, and reframing everyday self-care.</p>
          </div>
        </section>

        <section class="crescent-gallery" aria-label="Crescent project gallery" data-work-gallery data-work-gallery-sources={JSON.stringify([work2Pic1, work2Pic2, work2Pic3, work2Pic4, work2Pic5, work2Pic6])}>
          <span class="crescent-gallery__chrome" aria-hidden="true"><i></i><i></i><i></i><b></b></span>
          <button type="button" class="crescent-gallery__arrow crescent-gallery__arrow--previous" data-work-gallery-previous aria-label="Previous image"><img src={triangleLeft} alt="" /></button>
          <img class="crescent-gallery__image" src={work2Pic1} alt="Crescent project artwork" data-work-gallery-image />
          <button type="button" class="crescent-gallery__arrow crescent-gallery__arrow--next" data-work-gallery-next aria-label="Next image"><img src={triangleRight} alt="" /></button>
        </section>
        <footer class="crescent-footer">
          <button class="crescent-footer__top" type="button" data-work-modal-top aria-label="Back to top"><img src={arrowUp} alt="" /></button>
          <button type="button" data-work-modal-next>Next Project <img src={arrowRight} alt="" /></button>
        </footer>
      </div>
    </article>

    <article class="work-modal__window work-modal--crescent work-modal--holiday" data-work-modal-panel="2" role="dialog" aria-modal="true" aria-labelledby="work-modal-title-2" hidden>
      <header class="work-modal__bar">
        <span>Works</span>
        <button type="button" data-work-modal-close aria-label="Close Holiday Inn"><img src={closeIcon} alt="" /></button>
      </header>
      <div class="work-modal__body">
        <section class="crescent-intro holiday-intro">
          <div class="crescent-intro__meta">
            <p class="work-modal__number">03</p>
            <h3 id="work-modal-title-2">Holiday Inn</h3>
            <dl>
              <div><dt>Type of work:</dt><dd>Campaign</dd></div>
              <div><dt>Client:</dt><dd>Holiday Inn</dd></div>
              <div><dt>Year:</dt><dd>2024</dd></div>
              <div><dt>Participants:</dt><dd>Chu Phuong Anh, Cao Phuong Uyen, Hoang Trung Kien, Bui Tuan Thanh</dd></div>
            </dl>
          </div>
          <img class="crescent-intro__eiter" src={eiterLogo} alt="Eiter" />
          <div class="crescent-drag-area" aria-label="Holiday Inn image previews">
            {holidayDragItems.map(({ image, position }, card) => (
              <img class:list={["crescent-drag-card", "holiday-drag-card", `holiday-drag-card--${card + 1}`]} style={`position: absolute; ${position}`} src={image} alt="" draggable="false" data-modal-draggable />
            ))}
          </div>
        </section>

        <section class="crescent-copy">
          <span class="crescent-copy__marker" aria-hidden="true" style="display: block; width: 31px; height: 31px; margin: 0 0 26px; background: var(--color-mint);"></span>
          <span class="crescent-copy__markers crescent-copy__markers--right" aria-hidden="true" style="display: flex; gap: 35px; position: absolute; top: 16px; right: clamp(1.4rem, 6vw, 3.6rem);"><span class="crescent-copy__marker" style="display: block; flex: 0 0 31px; width: 31px; height: 31px; background: var(--color-mint);"></span><span class="crescent-copy__marker" style="display: block; flex: 0 0 31px; width: 31px; height: 31px; background: var(--color-mint);"></span></span>
          <h4>"A second A perfect stay"</h4>
          <div class="work-modal__columns">
            <p>Holiday Inn is a chain of hotels based in Atlanta, Georgia and a brand of IHG Hotels & Resorts. The chain was founded in 1952 by Kemmons Wilson, who opened the first location in Memphis, Tenessee. As of 2018, Holiday Inn has hotels at over 1,100 locations.
                <br>
                <br>
                The Holiday Inn brand wants people to enjoy every
                part of staying in their hotel even from smallest such as check-in experience through online. We ran a social advertising campaign designed to increase awareness and engagement for Holiday Inn online booking application.  The challenge was to communicate the convenience of booking accommodations through a simple and engaging digital experience.</p>
            <p>The campaign highlights key app features, including easy reservations, exclusive deals, and a seamless user journey. The visual direction combines vibrant imagery, dynamic layouts, and clear call-to-action messaging to attract both leisure and business travelers. Social media content was designed for multiple platforms to maximize reach and user interaction.
                <br>
                <br>
                The goal was to strengthen brand visibility, encourage app downloads, and position Holiday Inn as a convenient travel companion for modern travelers.</p>
          </div>
          <div class="crescent-logo"><img src={work3} alt="Holiday Inn logo" /></div>
          <h4 class="crescent-copy__statement">TVC Storyboard</h4>
          <div class="work-modal__columns">
            <p>The Holiday Inn brand wants people to enjoy every
                part of staying in their hotel even from smallest such as check-in experience through online. We ran a social advertising campaign designed to increase awareness and engagement for Holiday Inn online booking application.  The challenge was to communicate the convenience of booking accommodations through a simple and engaging digital experience.</p>
            <p>The Holiday Inn brand wants people to enjoy every
                part of staying in their hotel even from smallest such as check-in experience through online. We ran a social advertising campaign designed to increase awareness and engagement for Holiday Inn online booking application.  The challenge was to communicate the convenience of booking accommodations through a simple and engaging digital experience.</p>
          </div>
        </section>

        <section class="crescent-gallery" aria-label="Holiday Inn project gallery" data-work-gallery data-work-gallery-sources={JSON.stringify([work3Img1, work3Img2, work3Img3, work3Img4, work3Img5])}>
          <span class="crescent-gallery__chrome" aria-hidden="true"><i></i><i></i><i></i><b></b></span>
          <button type="button" class="crescent-gallery__arrow crescent-gallery__arrow--previous" data-work-gallery-previous aria-label="Previous image"><img src={triangleLeft} alt="" /></button>
          <img class="crescent-gallery__image" src={work3Img1} alt="Holiday Inn project artwork" data-work-gallery-image />
          <button type="button" class="crescent-gallery__arrow crescent-gallery__arrow--next" data-work-gallery-next aria-label="Next image"><img src={triangleRight} alt="" /></button>
        </section>
        <footer class="crescent-footer">
          <button class="crescent-footer__top" type="button" data-work-modal-top aria-label="Back to top"><img src={arrowUp} alt="" /></button>
          <button type="button" data-work-modal-next>Next Project <img src={arrowRight} alt="" /></button>
        </footer>
      </div>
    </article>

    {projects.slice(3).map((project, index) => (
      <article class="work-modal__window" data-work-modal-panel={index + 3} role="dialog" aria-modal="true" aria-labelledby={`work-modal-title-${index + 3}`} hidden>
        <header class="work-modal__bar">
          <span>Works</span>
          <button type="button" data-work-modal-close aria-label={`Close ${project.name}`}><img src={closeIcon} alt="" /></button>
        </header>
        <div class="work-modal__body">
          <section class="work-modal__intro">
            <div class="work-modal__meta">
              <p class="work-modal__number">0{index + 4}</p>
              <h3 id={`work-modal-title-${index + 3}`}>{project.heading}</h3>
              <dl>
                <div><dt>Type of work:</dt><dd>{project.type}</dd></div>
                <div><dt>Client:</dt><dd>{project.client}</dd></div>
                <div><dt>Year:</dt><dd>{project.year}</dd></div>
                <div><dt>Participants:</dt><dd>Chu Phuong Anh</dd></div>
              </dl>
            </div>
            <div class="work-modal__cards" aria-label={`${project.name} previews`}>
              {[0, 1, 2].map((card) => (
                <figure class:list={["work-modal__card", `work-modal__card--${card + 1}`]} data-modal-draggable>
                  <figcaption>{project.name.toLowerCase().replaceAll(" ", "-")}.png</figcaption>
                  <img src={project.preview} alt="" draggable="false" />
                </figure>
              ))}
            </div>
          </section>
          <section class="work-modal__story">
            <span class="work-modal__pixel" aria-hidden="true"></span>
            <span class="work-modal__pixel work-modal__pixel--right" aria-hidden="true"></span>
            <h4>{project.statement}</h4>
            <div class="work-modal__columns">
              <p>{project.copy}</p>
              <p>The selected pieces bring the visual language across print, digital and campaign touchpoints, with a clear idea and a lively, tactile point of view.</p>
            </div>
            <figure class="work-modal__feature"><img src={project.preview} alt="" /></figure>
          </section>
        </div>
      </article>
    ))}
  </div>
</section>

<style>
  .sr-only { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }
  .works-panel { position: relative; min-height: 100%; }
  .works-panel__grid { display: grid; grid-template-columns: repeat(3, minmax(7.5rem, 1fr)); gap: clamp(2rem, 5vw, 5rem) clamp(1.5rem, 6vw, 5rem); padding: 3.75em clamp(2.5rem, 6vw, 5rem) 1.5rem; }
  .work-folder { display: grid; gap: .85rem; padding: 0; border: 0; color: var(--color-ink); background: transparent; text-align: left; cursor: pointer; }
  .work-folder:disabled { opacity: 1; cursor: default; }
  .work-folder__art { position: relative; display: block; width: min(8.25rem, 100%); aspect-ratio: 1.34; perspective: 42rem; }
  .work-folder__back {
    position: absolute;
    inset: 6% 12% 4% 6%;
    display: block;
  }
  .work-folder__back::before {
    content: "";
    position: absolute;
    z-index: 0;
    inset: 0;
    background: var(--color-purple);
    clip-path: polygon(4% 0, 28% 0, 31% 7%, 100% 7%, 100% 15%, 13% 15%, 0 100%, 0 8%);
  }
  .work-folder__paper {
    position: absolute;
    z-index: 1;
    inset: 15% -11% 0 3%;
    display: block;
    overflow: visible;
  }
  .work-folder__paper::before {
    content: "";
    position: absolute;
    z-index: 0;
    inset: 0;
    background: var(--color-chrome);
    clip-path: polygon(10% 0, 100% 0, 87% 100%, 0 100%);
  }
  .work-folder__preview {
    position: absolute;
    z-index: 1;
    inset: 15% 15% 18% 17%;
    overflow: visible;
    clip-path: inset(-200% -100% 0 -100%);
  }
  .work-folder__preview img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: contain;
    transform: translateY(0) scale(1);
    transform-origin: center bottom;
    transition: transform 380ms var(--ease-out);
    will-change: transform;
  }
  .work-folder__front {
    position: absolute;
    z-index: 2;
    inset: 12% -7% 0 -3%;
    display: grid;
    place-items: end end;
    padding: .5rem 1.35rem .7rem .7rem;
    background: var(--color-mint);
    clip-path: polygon(17% 0, 100% 0, 82% 100%, 0 100%);
    transform-origin: center bottom;
    transform: perspective(42rem) rotateX(0deg);
    transition: transform 540ms var(--ease-out);
    will-change: transform;
  }
  .work-folder__front b { color: var(--color-purple); font: italic 700 1.35rem/1 var(--font-mono); }
  .work-folder__name { margin-left: .7rem; font: 700 13px/1.35 var(--font-mono); }
  .work-folder:hover .work-folder__front, .work-folder[aria-expanded="true"] .work-folder__front { transform: perspective(42rem) rotateX(-68deg); }
  .work-folder:hover .work-folder__preview img { transform: translateY(-3.1rem) scale(1.6); }
  .work-folder:focus-visible { outline: 3px solid var(--color-yellow); outline-offset: .35rem; }
  .works-panel__detail { position: absolute; z-index: 2; inset: auto 1.25rem 1.25rem; display: grid; gap: .65rem; padding: 1.5rem; border: .2rem solid var(--color-purple); border-radius: 1rem; color: var(--color-ink); background: var(--color-surface); box-shadow: .5rem .5rem 0 var(--color-mint); animation: detail-enter 320ms var(--ease-out); }
  .works-panel__detail button { position: absolute; top: .35rem; right: .65rem; border: 0; color: var(--color-purple); background: transparent; font-size: 1.35rem; cursor: pointer; }
  .works-panel__detail p { color: var(--color-purple); font: 600 .65rem/1 var(--font-mono); text-transform: uppercase; }
  .works-panel__detail h3 { font-size: 1.5rem; }
  .works-panel__detail span { color: var(--color-muted); font: .75rem/1.5 var(--font-mono); }
  .work-modal { position: fixed; z-index: 50; inset: 0; display: grid; place-items: center; padding: clamp(.75rem, 2vw, 2rem); }
  .work-modal[hidden], .work-modal__window[hidden] { display: none; }
  .work-modal__backdrop { position: absolute; inset: 0; border: 0; background: rgb(20 15 30 / .48); backdrop-filter: blur(9px); }
  .work-modal__window { position: relative; display: flex; flex-direction: column; width: min(100%, 56.5rem); height: min(100%, 58rem); overflow: hidden; color: var(--color-ink); background: var(--color-surface); box-shadow: 0 1.25rem 4rem rgb(20 15 30 / .38); animation: work-modal-enter 420ms var(--ease-out); }
  .work-modal__bar { position: relative; z-index: 3; display: flex; align-items: center; justify-content: space-between; min-height: 3.25rem; padding: 0 1rem; color: var(--color-mint); background: var(--color-purple); }
  .work-modal__bar > span { font: 700 24px/1 var(--font-mono); }
  .work-modal__bar button { display: grid; place-items: center; width: 1.4rem; height: 1.4rem; border: 0; color: var(--color-mint); background: transparent; font: 400 1rem/1 var(--font-mono); cursor: pointer; }
  .work-modal__bar button img { display: block; width: .72rem; height: .72rem; object-fit: contain; }
  :global(.site-footer) { z-index: 60 !important; }
  .work-modal__body { overflow: auto; }
  .work-modal__intro { position: relative; display: grid; grid-template-columns: minmax(13rem, .75fr) minmax(18rem, 1.25fr); min-height: 20.5rem; padding: 1.35rem clamp(1.4rem, 4vw, 3.5rem) 1.75rem; }
  .work-modal__number { margin: 0 0 .5rem; color: var(--color-mint); font: 700 1.35rem/1 var(--font-mono); }
  .work-modal__meta h3 { max-width: 15rem; margin: 0 0 1.15rem; color: var(--color-purple); font: 700 clamp(1.05rem, 2vw, 1.42rem)/1.08 var(--font-mono); }
  .work-modal__meta dl { margin: 0; font: 500 .53rem/1.38 var(--font-mono); }
  .work-modal__meta dl div { display: flex; gap: .28rem; }
  .work-modal__meta dt, .work-modal__meta dd { margin: 0; }
  .work-modal__cards { position: relative; min-height: 18rem; }
  .work-modal__card { position: absolute; z-index: 1; width: min(11rem, 46%); margin: 0; overflow: hidden; border-right: .22rem solid var(--color-mint); border-bottom: .22rem solid var(--color-mint); background: var(--color-surface); box-shadow: 0 0 0 .08rem var(--color-purple); cursor: grab; touch-action: none; user-select: none; }
  .work-modal__card:active { cursor: grabbing; }
  .work-modal__card--1 { top: 1rem; left: 24%; }
  .work-modal__card--2 { top: 6.8rem; left: 3%; }
  .work-modal__card--3 { top: 8rem; right: 4%; }
  .work-modal__card figcaption { height: .75rem; padding: .16rem .3rem; overflow: hidden; color: var(--color-surface); background: var(--color-purple); font: 400 .34rem/1 var(--font-mono); white-space: nowrap; }
  .work-modal__card img { display: block; width: 100%; aspect-ratio: 1.42; object-fit: cover; pointer-events: none; }
  .work-modal__story { position: relative; padding: 1rem clamp(1.4rem, 5vw, 4.5rem) 3rem; }
  .work-modal__pixel { display: block; width: .62rem; height: .62rem; margin: 0 0 1.65rem; background: var(--color-mint); }
  .work-modal__pixel--right { position: absolute; top: 1rem; right: clamp(1.4rem, 5vw, 4.5rem); }
  .work-modal__story h4 { margin: 0 0 1.25rem; font: 500 clamp(.8rem, 1.5vw, 1rem)/1.25 var(--font-mono); }
  .work-modal__columns { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: clamp(1rem, 5vw, 4rem); }
