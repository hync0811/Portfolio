---
import eiMain from "../../assets/ei-main.svg?url";

interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
---

<span class:list={["brand-mark", { "brand-mark--compact": compact }]} aria-hidden="true">
  <img src={eiMain} alt="" draggable="false" />
</span>

<style>
  .brand-mark {
    display: grid;
    width: 8rem;
    height: 8rem;
    place-items: center;
  }

  img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    user-select: none;
    -webkit-user-drag: none;
    pointer-events: none;
  }

  .brand-mark--compact {
    width: 8rem;
    height: 8rem;
    rotate: 8deg;
  }
</style>
