---
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
---

<span class:list={["brand-mark", { "brand-mark--compact": compact }]} aria-hidden="true">
  <span class="brand-mark__glyph">ei</span>
  {compact && <span class="brand-mark__eyes">••</span>}
</span>

<style>
  .brand-mark { display: inline-grid; place-items: center; color: var(--color-mint); font: 900 1.6rem/1 var(--font-sans); letter-spacing: -.18em; }
  .brand-mark--compact { position: relative; width: 4rem; height: 4rem; border-radius: .6rem; color: var(--color-surface); background: var(--color-mint); rotate: 8deg; }
  .brand-mark__eyes { position: absolute; color: var(--color-ink); font-size: 1rem; letter-spacing: -.2em; }
</style>
