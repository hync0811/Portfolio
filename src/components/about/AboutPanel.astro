---
import brandMark from "../../assets/ei-main.svg?url";
import loadingIcon from "../../assets/ic-loading.svg?url";
import work1 from "../../assets/works/work-1.svg?url";
import work2 from "../../assets/works/work-2.svg?url";
import work3 from "../../assets/works/work-3.svg?url";
import work4 from "../../assets/works/work-4.svg?url";
import work5 from "../../assets/works/work-5.svg?url";

const projects = [
  { name: "Lotus Water Puppet", preview: work1 },
  { name: "Crescent", preview: work2 },
  { name: "Holiday Inn", preview: work3 },
  { name: "Rong Vang Hoang Gia", preview: work4 },
  { name: "Antibiotic Abuse", preview: work5 },
];
---

<section class="about-panel" aria-labelledby="about-heading">
  <div class="about-panel__intro">
    <div>
      <p class="about-panel__greeting">Hi! My name is</p>
      <h1 id="about-heading">Phuong Anh</h1>
    </div>
    <div class="about-panel__brand">
      <img src={brandMark} alt="Eiter" />
      <p><b>↑</b><br />(or you can call me)</p>
    </div>
  </div>

  <div class="about-panel__markers" aria-hidden="true"><i></i><i></i><i></i></div>

  <div class="about-panel__skills">
    <p>I’m a graphic designer<br />from Vietnam<br />specializing in:</p>
    <p>Brand identities<br />Packaging design</p>
  </div>

  <div class="about-panel__story">
    <img src={loadingIcon} alt="" aria-hidden="true" />
    <p>As a graphic designer, I bring equal parts passion and critical thinking to design. Always eager to evolve, I refine my craft by diving headfirst into new experiences, analyzing what works, and constantly pushing for better results.</p>
    <p>I design with an open mind and a strong desire to explore new possibilities. While I’m still early in my journey, I treat every project as a chance to push my limits and bring bold ideas to life — always giving 100% to help a concept reach its full potential.</p>
  </div>

  <div class="about-panel__actions">
    <a href="#cv">Click here for my CV</a>
    <a class="about-panel__projects-link" href="#works" data-window-target="works">See my Projects</a>
  </div>

  <div class="about-panel__projects" aria-label="Selected projects">
    {projects.map(({ name, preview }, index) => (
      <div class="about-folder" role="listitem" aria-label={name}>
        <span class="about-folder__art" aria-hidden="true">
          <span class="about-folder__back">
            <span class="about-folder__paper">
              <span class="about-folder__preview"><img src={preview} alt="" /></span>
              <span class="about-folder__front"><b>{String(index + 1).padStart(2, "0")}</b></span>
            </span>
          </span>
        </span>
        <small>{name}</small>
      </div>
    ))}
  </div>

  <div class="about-panel__bottom-markers" aria-hidden="true"><i></i><i></i><i></i></div>
  <button class="about-panel__back-top" type="button" data-scroll-top aria-label="Back to top">↑</button>
</section>

<style>
  .about-panel { position: relative; display: grid; gap: clamp(2.5rem, 5vw, 4.5rem); padding: clamp(1.25rem, 3vw, 2.5rem); padding-bottom: 5rem; color: var(--color-ink); }
  .about-panel__intro { display: flex; align-items: center; justify-content: space-between; gap: 2rem; }
  .about-panel__greeting { margin-bottom: .5rem; font: 800 41px/1 var(--font-mono); }
  h1 { color: var(--color-purple); font: 800 58px/.95 var(--font-mono); letter-spacing: -.08em; }
  .about-panel__brand { display: grid; justify-items: center; gap: .35rem; width: clamp(8rem, 21vw, 13rem); text-align: center; }
  .about-panel__brand img { width: 100%; height: auto; }
  .about-panel__brand p { font: .68rem/1.3 var(--font-sans); }
  .about-panel__brand b { color: var(--color-purple); font: 900 1.5rem/1 var(--font-sans); }
  .about-panel__markers, .about-panel__bottom-markers { display: flex; justify-content: space-between; }
  .about-panel__markers i, .about-panel__bottom-markers i { width: 1.5rem; aspect-ratio: 1; background: var(--color-mint); }
  .about-panel__markers i:nth-child(2), .about-panel__bottom-markers i:nth-child(2) { margin-left: auto; }
  .about-panel__markers i:nth-child(3), .about-panel__bottom-markers i:nth-child(3) { margin-left: 1.75rem; }
  .about-panel__skills { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; color: var(--color-purple); font: 700 clamp(1rem, 2vw, 1.55rem)/1.15 var(--font-mono); }
  .about-panel__skills p:last-child { align-self: end; }
  .about-panel__story { display: grid; grid-template-columns: 1fr 1fr; grid-template-areas: "icon copy" "bio bio"; gap: 2.5rem 4rem; align-items: center; }
  .about-panel__story img { grid-area: icon; width: 6rem; justify-self: center; rotate: 23deg; }
  .about-panel__story p { font: .8rem/1.35 var(--font-sans); }
  .about-panel__story p:first-of-type { grid-area: copy; }
  .about-panel__story p:last-of-type { grid-area: bio; max-width: 28rem; }
  .about-panel__actions { display: grid; justify-items: end; gap: 4rem; }
  .about-panel__actions a { color: var(--color-purple); font: 700 clamp(1rem, 2vw, 1.55rem)/1 var(--font-mono); text-decoration: none; }
  .about-panel__projects-link { padding: .75rem 1rem; color: var(--color-ink) !important; background: var(--color-mint); }
  .about-panel__projects { display: grid; grid-template-columns: repeat(3, minmax(6rem, 1fr)); gap: 2.5rem 3.5rem; }
  .about-folder { display: grid; gap: .65rem; color: var(--color-ink); }
  .about-folder__art { position: relative; display: block; width: min(8rem, 100%); aspect-ratio: 1.34; perspective: 42rem; }
  .about-folder__back { position: absolute; inset: 6% 12% 4% 6%; display: block; }
  .about-folder__back::before { content: ""; position: absolute; inset: 0; background: var(--color-purple); clip-path: polygon(4% 0, 28% 0, 31% 7%, 100% 7%, 100% 15%, 13% 15%, 0 100%, 0 8%); }
  .about-folder__paper { position: absolute; z-index: 1; inset: 15% -11% 0 3%; display: block; overflow: visible; }
  .about-folder__paper::before { content: ""; position: absolute; inset: 0; background: var(--color-chrome); clip-path: polygon(10% 0, 100% 0, 87% 100%, 0 100%); }
  .about-folder__preview { position: absolute; z-index: 1; inset: 15% 15% 18% 17%; overflow: visible; clip-path: inset(-200% -100% 0 -100%); }
  .about-folder__preview img { display: block; width: 100%; height: 100%; max-width: none; object-fit: contain; transform: translateY(0) scale(1); transform-origin: center bottom; transition: transform 380ms var(--ease-out); }
  .about-folder__front { position: absolute; z-index: 2; inset: 12% -7% 0 -3%; display: grid; place-items: end end; padding: .5rem 1.35rem .7rem .7rem; background: var(--color-mint); clip-path: polygon(17% 0, 100% 0, 82% 100%, 0 100%); transform: perspective(42rem) rotateX(0); transform-origin: center bottom; transition: transform 540ms var(--ease-out); }
  .about-folder__front b { color: var(--color-purple); font: italic 700 1.35rem/1 var(--font-mono); }
  .about-folder small { font: .62rem/1.3 var(--font-mono); }
  .about-folder:hover .about-folder__front { transform: perspective(42rem) rotateX(-68deg); }
  .about-folder:hover .about-folder__preview img { transform: translateY(-3.1rem) scale(1.6); }
  .about-panel__back-top { position: absolute; right: clamp(1.25rem, 3vw, 2.5rem); bottom: 1.5rem; display: grid; width: 3rem; aspect-ratio: 1; place-items: center; padding: 0; border: 0; color: var(--color-purple); background: var(--color-mint); font: 800 1.55rem/1 var(--font-mono); cursor: pointer; }
  .about-panel__back-top:hover, .about-panel__back-top:focus-visible { color: var(--color-surface); background: var(--color-purple); }
  @media (max-width: 40rem) { .about-panel__intro, .about-panel__skills, .about-panel__story { grid-template-columns: 1fr; } .about-panel__intro { align-items: start; } .about-panel__story { grid-template-areas: "icon" "copy" "bio"; } .about-panel__projects { grid-template-columns: repeat(2, minmax(6rem, 1fr)); } }
</style>
